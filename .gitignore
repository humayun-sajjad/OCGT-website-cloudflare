# Marketing video referenced by OCGT_website.html (others stay ignored):
!marketing/signal-2021-12-25-17-04-33-257.mp4

# ── Dev-only artifacts (blocked from public serving by .htaccess) ──
ocgt-BUILD-TOOL.html
ocgt-split-index.html
ocgt-app.js
ocgt-data.js
ocgt-design-dark.css
ocgt-design-light.css
_sample_pcl.py
pcl.bin
three.min.js

# ── Generated/large binary documents ──
*.docx
*.doc
*.xls
*.xlsx
*.pdf
!OCGT_Website_Audit_Report.md
!OCGT_Fix_Report.md

# ── Generated upload archives ──
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# ══════════════════════════════════════════════════════════════
# KEEP IN REPO (whitelist — these are essential):
#
# Root HTML/CSS/JS:
#   OCGT_website.html
#   index.html
#
# Deployment + config:
#   .htaccess
#   sitemap.xml
#   robots.txt
#   manifest.webmanifest
#
# Documentation:
#   README.md
#   OCGT_Website_Audit_Report.md
#   OCGT_Fix_Report.md
#   OCGT_Website_Reference.md
#   OCGT_Content_Template.md
#
# Design tokens (branding):
#   221129_OCGT_Logo Farbwahl.pdf   — keep (brand spec)
#   Images/LOGO_black.png
#   logos/                           — full icon system (SVG+PNG, small)
#
# Poster/hero assets:
#   04 Videos/Hero-web-compact.mp4
#   04 Videos/Hero-web-compact.webm
#   04 Videos/hero-poster.jpg
#   04 Videos/hero-poster-1600.jpg
# ══════════════════════════════════════════════════════════════

# ─── Media — hosted on R2, not in git ─────────────────────────────────
Images/
Videos/
04 Videos/
marketing/
logos/
icons/
company_logos/

# ─── Local backups + build artifacts ─────────────────────────────────
_media_backups/
*.bak
*.b1bak
*.original.mp4
optimize.log
optimize-videos.log
